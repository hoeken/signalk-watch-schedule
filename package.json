    "node": ">=18"
  },
  "files": [
    "index.js",
    "src/",
    "public/"
  ],
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  }
}

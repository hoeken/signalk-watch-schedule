{
  "name": "signalk-watch-schedule",
  "version": "0.1.0",
  "description": "Crew watch schedule for offshore and overnight sailing — SignalK plugin + webapp",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build:webapp": "vite build --config webapp/vite.config.js",
    "dev:webapp": "vite --config webapp/vite.config.js",
    "test": "node --test",
    "prepublishOnly": "npm run build:webapp"
